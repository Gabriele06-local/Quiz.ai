# Copia in .env (non committare .env)
# Su Netlify: Site settings → Environment variables (stessi nomi)
#
# Il build genera public/supabase-config.js (gitignored) con solo URL + chiave anon.
# Non usare mai SUPABASE_SERVICE_ROLE_KEY nel sito o nelle variabili di build esposte al client.

# URL del progetto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Chiave pubblica (anon / publishable) — mai la service_role nel frontend
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_or_anon_key_here

# Alternativa accettata dallo script di build (stesso significato):
# SUPABASE_URL=...
# SUPABASE_ANON_KEY=...
